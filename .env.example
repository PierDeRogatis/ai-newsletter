# Copy this file to .env for local testing (never commit .env)

# Groq API key — get one free at console.groq.com
GROQ_API=gsk_...

# Gmail address used as the "From" address and to receive failure alerts
SENDER_EMAIL=you@gmail.com
# Gmail App Password — used only for failure alert emails (not the main send)
# Google Account → Security → 2-Step Verification → App passwords
SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# Email address that receives failure alerts
RECIPIENT_EMAIL=you@example.com

# Brevo — transactional email API (main newsletter send)
# Settings → API Keys in the Brevo dashboard
BREVO_KEY=xkeysib-...
# Brevo contact list ID to send the newsletter to (Contacts → Lists)
BREVO_LIST_ID=3

# Telegram — optional, skip step if missing
TELEGRAM_BOT_TOKEN=1234567890:ABCDef...
# Channel or group chat ID (e.g. -100123456789)
TELEGRAM_CHAT_ID=-100123456789

# Substack — optional, only needed for direct-publish (currently disabled; Substack imports via RSS)
SUBSTACK_SID=
SUBSTACK_URL=https://yourpub.substack.com

# Twitter/X — optional, skip step if any credential is missing
# developer.twitter.com → Project → App → Keys and Tokens
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=

# LinkedIn — optional, skip step if any credential is missing
# developer.linkedin.com → OAuth 2.0 → w_member_social scope
# LINKEDIN_AUTHOR_URN: your personal URN, e.g. urn:li:person:abc123def456
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AUTHOR_URN=
